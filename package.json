{
  "name": "rhizome",
  "private": true,
  "version": "1.0.5",
  "productName": "Rhizome",
  "description": "Rhizome - 简约的本地音乐播放器 | 支持无损音频、桌面歌词、频谱可视化",
  "author": "AutumnDew",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --no-open",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:9000 && npm run electron\"",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force dist, dist_electron, node_modules/.vite -ErrorAction SilentlyContinue\"",
    "clean:app": "powershell -Command \"Remove-Item -Recurse -Force $env:APPDATA\\Rhizome -ErrorAction SilentlyContinue\"",
    "clean:all": "npm run clean && npm run clean:app",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "element-plus": "^2.13.6",
    "flac-metadata": "^0.1.1",
    "jsmediatags": "^3.9.7",
    "music-metadata": "^11.12.3",
    "music-metadata-browser": "^2.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "electron": "^41.0.5",
    "electron-builder": "^24.13.3",
    "terser": "^5.46.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.rhizome.music.player",
    "productName": "Rhizome",
    "copyright": "Copyright 漏 2026 AutumnDew",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "icon": "electron/icons/img.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rhizome 音乐播放器"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "asar": true,
    "compression": "maximum"
  }
}